{
  "version": "0.1",
  "notes": [
    "Pilot schema derived from analysis/data/DRAFT Product Catalog Requirements.pdf.",
    "Only deterministic extraction is in scope for the first pass."
  ],
  "categories": {
    "chemicals_solvents": {
      "label": "Chemicals and Solvents",
      "required_fields": [
        {
          "name": "CAS Number",
          "type": "text",
          "extractor": "regex",
          "examples": ["7647-14-5"]
        },
        {
          "name": "Purity",
          "type": "text",
          "extractor": "regex_or_grade_dictionary",
          "examples": [">=99%", "ACS Grade", "HPLC Grade"]
        }
      ]
    },
    "molecular_biology_reagents": {
      "label": "Molecular Biology Reagents",
      "required_fields": [
        {
          "name": "Sub-Type",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Primer", "Probe", "siRNA", "Enzyme", "Nucleotide", "gRNA", "Cas Nuclease", "shRNA", "miRNA", "Other"]
        },
        {
          "name": "Target Gene / Region",
          "type": "text",
          "extractor": "field_or_name_pattern",
          "examples": ["BRCA1", "TP53", "GAPDH"]
        },
        {
          "name": "Target Species",
          "type": "multi-select",
          "extractor": "controlled_vocabulary",
          "values": ["Human", "Mouse", "Rat", "Zebrafish", "Drosophila", "C. elegans", "Yeast", "E. coli", "Bovine", "Porcine", "Chicken", "Rabbit"]
        }
      ]
    },
    "lab_supplies_consumables": {
      "label": "Lab Supplies and Consumables",
      "required_fields": [
        {
          "name": "Material",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Polypropylene", "Polystyrene", "Polyethylene", "Glass", "Borosilicate Glass", "PTFE", "Nitrile", "Latex", "Stainless Steel", "PVC", "Silicone", "Other"]
        },
        {
          "name": "Sterility",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Sterile", "Non-Sterile", "Sterilizable"]
        },
        {
          "name": "Capacity Volume Size",
          "type": "text",
          "extractor": "regex",
          "examples": ["15 mL", "200 uL", "96-well", "100 mm"]
        },
        {
          "name": "Size Amount",
          "type": "number",
          "extractor": "derived_from_capacity_volume_size",
          "examples": ["15", "200", "96", "100"]
        },
        {
          "name": "Size Unit",
          "type": "picklist",
          "extractor": "derived_from_capacity_volume_size",
          "values": ["nL", "uL", "mL", "L", "ug", "mg", "g", "kg", "mm", "cm", "in", "well"]
        },
        {
          "name": "Pack Size",
          "type": "number",
          "extractor": "regex",
          "examples": ["100", "500", "96"]
        },
        {
          "name": "Color",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Black", "Blue", "Brown", "Clear", "Green", "Orange", "Pink", "Purple", "Red", "White", "Yellow", "Amber", "Natural", "Assorted"]
        }
      ]
    },
    "antibodies": {
      "label": "Antibodies",
      "required_fields": [
        {
          "name": "Target / Specificity",
          "type": "text",
          "extractor": "pattern_dictionary",
          "examples": ["CD4", "p53", "Beta-Actin"]
        },
        {
          "name": "Host Species",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Mouse", "Rabbit", "Goat", "Rat", "Donkey", "Chicken", "Sheep", "Other"]
        },
        {
          "name": "Clonality",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Monoclonal", "Polyclonal", "Recombinant Monoclonal"]
        },
        {
          "name": "Reactivity",
          "type": "multi-select",
          "extractor": "controlled_vocabulary",
          "examples": ["Human", "Mouse", "Rat"]
        },
        {
          "name": "Application",
          "type": "multi-select",
          "extractor": "controlled_vocabulary",
          "values": ["FC", "WB", "IHC", "IF", "ELISA", "IP", "ChIP", "ICC", "Neutralization", "Other"]
        }
      ]
    },
    "proteins_peptides": {
      "label": "Proteins and Peptides",
      "required_fields": [
        {
          "name": "Source Organism",
          "type": "multi-select",
          "extractor": "controlled_vocabulary",
          "values": ["Human", "Mouse", "Rat", "Rabbit", "Bovine", "Porcine", "E. coli", "HEK293", "CHO", "Baculovirus", "Yeast", "Wheat Germ"]
        },
        {
          "name": "Form",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Lyophilized", "Liquid", "Frozen"]
        },
        {
          "name": "Physical State",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Solid", "Liquid", "Powder", "Solution"]
        },
        {
          "name": "Purity",
          "type": "text",
          "extractor": "regex_or_grade_dictionary",
          "examples": [">95%", ">=90%", "HPLC Grade"]
        },
        {
          "name": "Activity",
          "type": "text",
          "extractor": "regex",
          "examples": ["ED50 < 1 ng/mL", "Specific Activity: 1.0 x 10^6 U/mg"]
        }
      ]
    },
    "kits_assays": {
      "label": "Kits and Assays",
      "required_fields": [
        {
          "name": "Sub-Type",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["ELISA Kit", "Extraction Kit", "Detection Kit", "Substrate", "Blocking Buffer", "Diluent", "Stabilizer", "Signal Enhancer", "Lateral Flow", "Other"]
        },
        {
          "name": "Application",
          "type": "multi-select",
          "extractor": "controlled_vocabulary",
          "values": ["ELISA", "Western Blot", "IHC", "Lateral Flow", "Multiplex", "Cell Isolation", "Other"]
        },
        {
          "name": "Detection Method",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Chromogenic", "Chemiluminescent", "Fluorescent", "Electrochemical"]
        },
        {
          "name": "Target Enzyme",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["HRP", "AP", "Universal"]
        },
        {
          "name": "Physical State",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Liquid", "Lyophilized", "Powder"]
        },
        {
          "name": "Storage Conditions",
          "type": "picklist",
          "extractor": "regex_or_controlled_vocabulary",
          "values": ["2-8°C", "-20°C", "-80°C", "Room Temperature"]
        }
      ]
    }
  }
}
