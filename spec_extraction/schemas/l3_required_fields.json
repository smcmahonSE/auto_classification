{
  "version": "0.1",
  "notes": [
    "Pilot schema derived from analysis/data/DRAFT Product Catalog Requirements.pdf.",
    "Only deterministic extraction is in scope for the first pass."
  ],
  "categories": {
    "chemicals_solvents": {
      "label": "Chemicals and Solvents",
      "required_fields": [
        {
          "name": "CAS Number",
          "type": "text",
          "extractor": "regex",
          "examples": ["7647-14-5"]
        },
        {
          "name": "Purity",
          "type": "text",
          "extractor": "regex_or_grade_dictionary",
          "examples": [">=99%", "ACS Grade", "HPLC Grade"]
        }
      ]
    },
    "molecular_biology_reagents": {
      "label": "Molecular Biology Reagents",
      "required_fields": [
        {
          "name": "Sub-Type",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Primer", "Probe", "siRNA", "Enzyme", "Nucleotide", "gRNA", "Cas Nuclease", "shRNA", "miRNA", "Other"]
        },
        {
          "name": "Target Gene / Region",
          "type": "text",
          "extractor": "field_or_name_pattern",
          "examples": ["BRCA1", "TP53", "GAPDH"]
        }
      ]
    },
    "lab_supplies_consumables": {
      "label": "Lab Supplies and Consumables",
      "required_fields": [
        {
          "name": "Material",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Polypropylene", "Polystyrene", "Polyethylene", "Glass", "Borosilicate Glass", "PTFE", "Nitrile", "Latex", "Stainless Steel", "PVC", "Silicone", "Other"]
        },
        {
          "name": "Sterility",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Sterile", "Non-Sterile", "Sterilizable"]
        },
        {
          "name": "Capacity / Volume / Size",
          "type": "text",
          "extractor": "regex",
          "examples": ["15 mL", "200 uL", "96-well", "100 mm"]
        },
        {
          "name": "Pack Size",
          "type": "text",
          "extractor": "regex",
          "examples": ["100/pk", "500/cs", "Pack of 96"]
        },
        {
          "name": "Color",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Black", "Blue", "Brown", "Clear", "Green", "Orange", "Pink", "Purple", "Red", "White", "Yellow", "Amber", "Natural", "Assorted"]
        }
      ]
    },
    "antibodies": {
      "label": "Antibodies",
      "required_fields": [
        {
          "name": "Target / Specificity",
          "type": "text",
          "extractor": "pattern_dictionary",
          "examples": ["CD4", "p53", "Beta-Actin"]
        },
        {
          "name": "Host Species",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Mouse", "Rabbit", "Goat", "Rat", "Donkey", "Chicken", "Sheep", "Other"]
        },
        {
          "name": "Clonality",
          "type": "picklist",
          "extractor": "controlled_vocabulary",
          "values": ["Monoclonal", "Polyclonal", "Recombinant Monoclonal"]
        },
        {
          "name": "Reactivity",
          "type": "multi-select",
          "extractor": "controlled_vocabulary",
          "examples": ["Human", "Mouse", "Rat"]
        },
        {
          "name": "Application",
          "type": "multi-select",
          "extractor": "controlled_vocabulary",
          "values": ["FC", "WB", "IHC", "IF", "ELISA", "IP", "ChIP", "ICC", "Neutralization", "Other"]
        }
      ]
    }
  }
}
